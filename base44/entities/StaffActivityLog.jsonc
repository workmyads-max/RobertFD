{
  "name": "StaffActivityLog",
  "type": "object",
  "permissions": {
    "read": "admin",
    "create": "admin",
    "update": "admin",
    "delete": "admin"
  },
  "properties": {
    "staff_email": {
      "type": "string"
    },
    "staff_name": {
      "type": "string"
    },
    "role_name": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "action_category": {
      "type": "string",
      "enum": [
        "auth",
        "users",
        "challenges",
        "payouts",
        "kyc",
        "risk",
        "affiliates",
        "support",
        "settings",
        "staff",
        "system"
      ]
    },
    "target_entity": {
      "type": "string"
    },
    "target_id": {
      "type": "string"
    },
    "target_user_email": {
      "type": "string"
    },
    "details": {
      "type": "object"
    },
    "ip_address": {
      "type": "string"
    },
    "user_agent": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "blocked"
      ],
      "default": "success"
    }
  },
  "required": [
    "staff_email",
    "action"
  ]
}